        },
        {
          "subject": "subtropical high-pressure system over the Arabian Peninsula",
          "relation": "causes",
          "object": "extreme summer temperature variation",
          "quote": "The influence of a subtropical high-pressure system over the Arabian Peninsula is associated with extreme summer temperature variation"
