        }
      ],
      "n_triples": 1
    },
    {
      "id": "cite_ref_heatwave_circulation",
      "ntype": "Citation",
      "label": "ScienceDirect, Atmospheric Research",
      "desc": "Extreme summer temperatures in Saudi Arabia and large-scale circulation",
      "url": "https://www.sciencedirect.com/science/article/abs/pii/S0169809519301747",
      "evidence": [
        {
          "subject": "powerful solar radiation and persistent high-pressure systems",
          "relation": "causes",
