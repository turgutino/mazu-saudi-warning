    {
      "id": "cite_ref_devries2013",
      "ntype": "Citation",
      "label": "de Vries et al. (2013), J. Geophys. Res. Atmos.",
      "desc": "Extreme precipitation events in the Middle East: Dynamics of the Active Red Sea Trough",
      "url": "https://agupubs.onlinelibrary.wiley.com/doi/full/10.1002/jgrd.50569",
      "evidence": [
        {
          "subject": "eastward-migrating Mediterranean cyclone",
          "relation": "joins",
          "object": "extension of the Sudan low-pressure zone (the Red Sea Trough)",
          "quote": "an eastward-migrating Mediterranean cyclone joined an extension of the Sudan low-pressure zone (the Red Sea Trough)"
        },
        {
          "subject": "stationary anticyclone over the southeastern Arabian Peninsula (the Arabian Anticyclone)",
          "relation": "produces",
          "object": "clockwise flow that supplied moisture from the Arabian Sea and the Red Sea",
          "quote": "a stationary anticyclone over the southeastern Arabian Peninsula (the Arabian Anticyclone) produced a clockwise flow that supplied moisture from the Arabian Sea and the Red Sea"
        },
        {
          "subject": "upper-level tropospheric instability combined with this moisture supply",
          "relation": "produces",
          "object": "deep moist convection",
          "quote": "upper-level tropospheric instability combined with this moisture supply to produce deep moist convection"
        },
        {
          "subject": "deep moist convection",
          "relation": "results in",
          "object": "a quasi-stationary mesoscale convective system and heavy rainfall over Jeddah",
          "quote": "resulting in a quasi-stationary mesoscale convective system and heavy rainfall over Jeddah"
        },
        {
          "subject": "The Red Sea Trough",
          "relation": "enhances",
          "object": "low-level moisture transport and convergence",
          "quote": "The Red Sea Trough enhances low-level moisture transport and convergence"
        },
        {
          "subject": "The Red Sea Trough",
          "relation": "precedes",
          "object": "deep convection and mesoscale convective system development",
          "quote": "often acting as a precursor to deep convection and mesoscale convective system development"
        }
      ],
      "n_triples": 6
    },
    {
      "id": "cite_ref_redsea_topo",
      "ntype": "Citation",
      "label": "ResearchGate case study",
      "desc": "On the Effect of Red Sea and Topography on Rainfall over Saudi Arabia",
      "url": "https://www.researchgate.net/publication/336928573",
      "evidence": [
        {
          "subject": "Surface fluxes over the Red Sea",
          "relation": "regulates",
          "object": "low-level moist-air convergence prior to convection initiation and development",
          "quote": "Surface fluxes over the Red Sea play an important role in regulating low-level moist-air convergence prior to convection initiation and development"
        },
        {
          "subject": "Red Sea water",
          "relation": "affects",
          "object": "regional rainfall",
          "quote": "Red Sea water is estimated to affect regional rainfall by about 30 to 40 percent"
        },
        {
          "subject": "strong convergence areas over the Red Sea",
          "relation": "enhances",
          "object": "uplift motion",
          "quote": "strong convergence areas form over the Red Sea that enhance uplift motion"
        },
        {
          "subject": "strong convergence areas over the Red Sea",
          "relation": "strengthens",
          "object": "low-level jets",
          "quote": "strengthen low-level jets"
        },
        {
          "subject": "strong convergence areas over the Red Sea",
          "relation": "creates",
          "object": "a conditionally unstable atmosphere that favours cyclonic system development",
          "quote": "create a conditionally unstable atmosphere that favours cyclonic system development"
        }
      ],
      "n_triples": 5
    },
    {
      "id": "cite_ref_heatflux_era5",
      "ntype": "Citation",
      "label": "MDPI Atmosphere (2019)",
      "desc": "Surface Heat Fluxes over the Northern Arabian Gulf and Red Sea (ERA5/MERRA2)",
      "url": "https://www.mdpi.com/2073-4433/10/9/504",
      "evidence": [
        {
          "subject": "stronger winds combined with drier air",
